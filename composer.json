{
    "name": "roldante05/scaffolding-factory",
    "description": "A powerful CLI tool to scaffold Laravel 13 and PHP Vanilla projects with Docker/Sail, auth kits, and modern frontend setup.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.2",
        "symfony/process": "^7.2",
        "laravel/prompts": "^0.3.17"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.1"
    },
    "authors": [
        {
            "name": "Dante Roldan",
            "email": "roldante05@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Roldante05\\ScaffoldingFactory\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/scaffold"
    ],
    "scripts": {
        "test": "pest"
    }
}
