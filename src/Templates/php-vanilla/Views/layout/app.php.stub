</head>
<body class="{{USE_TAILWIND}}bg-slate-100 text-slate-900 antialiased m-0{{/USE_TAILWIND}}">

    <?php if (class_exists('\App\Core\Auth') && \App\Core\Auth::check()): ?>
        <!-- Dashboard layout (logged in) -->
        {{USE_TAILWIND}}
        <div class="min-h-screen flex">
            <?php require_once __DIR__ . '/sidebar.php'; ?>
            <div class="flex-1 flex flex-col">
                <?php require_once __DIR__ . '/header.php'; ?>
                <main class="p-8">
                    <?= $content ?? '' ?>
                </main>
            </div>
        </div>
        {{/USE_TAILWIND}}
        {{USE_BOOTSTRAP}}
        <div class="container-fluid">
            <div class="row">
                <?php require_once __DIR__ . '/sidebar.php'; ?>
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 bg-light min-vh-100">
                    <?php require_once __DIR__ . '/header.php'; ?>
                    <?= $content ?? '' ?>
                </main>
            </div>
        </div>
        {{/USE_BOOTSTRAP}}
    <?php else: ?>
        <!-- Public layout (not logged in) -->
        {{USE_TAILWIND}}
        <div class="bg-gray-950 min-h-screen relative flex flex-col">
            <?php require_once __DIR__ . '/../nav.php'; ?>
            <main class="flex-1 relative">
                <div class="container mx-auto px-6 relative z-10">
                    <?= $content ?? '' ?>
                </div>
                <div class="absolute inset-0 overflow-hidden pointer-events-none">
                    <div class="absolute top-0 right-0 -translate-y-1/4 translate-x-1/4 w-[800px] h-[800px] bg-indigo-950 rounded-full blur-3xl opacity-30 -z-10"></div>
                    <div class="absolute bottom-0 left-0 translate-y-1/4 -translate-x-1/4 w-[600px] h-[600px] bg-violet-950 rounded-full blur-3xl opacity-30 -z-10"></div>
                </div>
            </main>
        </div>
        {{/USE_TAILWIND}}
        {{USE_BOOTSTRAP}}
        <div class="bg-dark min-vh-100 d-flex flex-column">
            <?php require_once __DIR__ . '/../nav.php'; ?>
            <main class="flex-grow-1 py-5">
                <div class="container">
                    <?= $content ?? '' ?>
                </div>
            </main>
        </div>
        {{/USE_BOOTSTRAP}}
    <?php endif; ?>

