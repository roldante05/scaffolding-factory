            <?php else: ?>
                <h2 class="text-2xl font-bold text-white mb-4">Migrations</h2>
                <p class="text-gray-400 leading-relaxed mb-4">
                    Migrations are defined as PHP classes in <code class="text-indigo-400">migrations/</code>. 
