namespace App\Controllers;
 
use App\Core\Controller;
use App\Core\Auth;
 
class HomeController extends Controller
{
    public function index(): void
    {
        $this->render("welcome", [
            "title" => "Welcome"
        ]);
    }
 
    public function home(): void
    {
        Auth::requireAuth();
        $this->render("home", [
            "user" => Auth::user()["name"]
        ]);
    }
}</code></pre>
