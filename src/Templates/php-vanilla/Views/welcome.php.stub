                <?php endif; ?>
                <pre class="bg-dark border border-secondary rounded p-4 text-light small"><code>&lt;?php

namespace App\Controllers;

use App\Core\Controller;
use App\Core\Auth;

class HomeController extends Controller
{
    public function index(): void
    {
        $this-&gt;render("welcome");
    }

    public function home(): void
    {
        Auth::requireAuth();
        $this-&gt;render("home", [
            "user" =&gt; Auth::user()["name"]
        ]);
    }
}</code></pre>
            </section>

