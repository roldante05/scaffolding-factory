{
    "name": "roldante05/chephp",
    "description": "PHP Vanilla project generated by Scaffolding Factory",
    "type": "project",
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "migrate": "php che migrate",
        "rollback": "php che rollback",
        "serve": "php -S localhost:8080"
    }
}
